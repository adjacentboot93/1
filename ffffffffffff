local function tableCount(tbl)
	local count = 0
	for _ in pairs(tbl) do
		count += 1
	end
	return count
end

local function purgeAllNameParts()
	for _, obj in ipairs(highlightNameParts:GetChildren()) do
		obj:Destroy()
	end

	table.clear(targetedParts)
end

local function refreshESPNames()
	purgeAllNameParts()
	
	for player in pairs(targetedParts) do
		removeHighlightNamePart(player)
	end

	local count = tableCount(selectedPlayers)

	if count < 2 then
		return
	end

	for player in pairs(selectedPlayers) do
		if player.Character then
			createHighLightNamePart(player)
		end
	end
end

local function syncESP(player)
	local character = player.Character
	
	if not character or not character.Parent then
		return
	end
	
	local data = getPlayerData(player)

	local shouldHaveESP = selectedPlayers[player]
	
	if not shouldHaveESP then
		removeHighlightNamePart(player)
	end
	
	local character = player.Character

	if not character then return end

	if shouldHaveESP then
		if not data.highlight or not data.highlight.Parent or data.highlight.Parent ~= character then
			data.highlight = createHighlight(player, character)
		end
	else
		if data.highlight then
			data.highlight:Destroy()
			data.highlight = nil
		end
	end

	refreshESPNames()

	if data.button then
		buttonStates[data.button] = shouldHaveESP or false
		setButtonState(data.button)
	end
end

function setButtonState(button)
	local buttonBg = button:FindFirstChild("playerNameFrame")
	if not buttonBg then
		return
	end

	local enabled = buttonStates[button] == true or hoverStates[button] == true

	local goal = enabled and targetTransparency or baseTransparency

	tweenService:Create(buttonBg, tweenInfo, goal):Play()
end

function connectButton(button)
	if connectedButtons[button] then
		return
	end

	connectedButtons[button] = true
	
	local player = players:FindFirstChild(button.Name)
	
	if not player then
		return
	end
	
	buttonStates[button] = false
	hoverStates[button] = false
	
	espRegistry[player] = espRegistry[player] or {}
	espRegistry[player].button = button

	button.Activated:Connect(function()
		local newState = not buttonStates[button]
		
		buttonStates[button] = newState
		
		setButtonState(button, newState)
		
		local player = game.Players:FindFirstChild(button.Name)
		
		if player then
			espHandler(player)
		end
	end)

	button.MouseEnter:Connect(function()
		hoverStates[button] = true
		setButtonState(button)
	end)

	button.MouseLeave:Connect(function()
		hoverStates[button] = false
		setButtonState(button)
	end)
	
	if pendingAllESP[player] then
		pendingAllESP[player] = nil
		task.defer(function()
			espHandler(player)
		end)
	end
end

