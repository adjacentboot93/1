local cameraPart = nil
local cameraLoop = nil
local yaw = 0
local pitch = 0
local sensitivity = 0.002
local maxPitch = math.rad(80)
local freecamActive = false
local keysDown = {}


uis.InputBegan:Connect(function(input, gameProcessed)
	if input.UserInputType ~= Enum.UserInputType.Keyboard then
		return
	end

	keysDown[input.KeyCode] = true

	if freecamEnabled == true then
		if keysDown[inputKeycode] and keysDown[Enum.KeyCode.RightBracket] then
			local runService = game:GetService("RunService")
			local players = game:GetService("Players")
			local player = players.LocalPlayer
			local playerLocation = player.Character.Head.Position
			local playerModule = require(player:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule"))
			local playerControls = playerModule:GetControls()
			local camera = game.Workspace.CurrentCamera

			if not game.Workspace:FindFirstChild("cameraPart") then
				freecamActive = true
				cameraPart = Instance.new("Part")
				cameraPart.Name = "cameraPart"
				cameraPart.Parent = game.Workspace
				cameraPart.Position = playerLocation
				cameraPart.Anchored = true
				cameraPart.CanCollide = false
				cameraPart.Transparency = 1
				camera.CameraType = Enum.CameraType.Scriptable
				uis.MouseBehavior = Enum.MouseBehavior.LockCenter
				uis.MouseIconEnabled = false
				playerControls:Disable()
				print("Griddle Menu (Freecam): Freecam active")

				local _, y, _ = player.Character.Head.CFrame:ToEulerAnglesYXZ()
				yaw = y
				pitch = 0

				cameraLoop = runService.RenderStepped:Connect(function(dt)
					local delta = uis:GetMouseDelta()
					local baseSpeed = 25
					local speed = baseSpeed

					yaw -= delta.X * sensitivity
					pitch -= delta.Y * sensitivity

					pitch = math.clamp(pitch, -maxPitch, maxPitch)

					local rotation = CFrame.Angles(0, yaw, 0) * CFrame.Angles(pitch, 0, 0)

					local move = Vector3.zero

					if keysDown[Enum.KeyCode.LeftShift] then
						speed = speed * 2
					end

					if keysDown[Enum.KeyCode.LeftControl] then
						speed = speed * 0.5
					end

					if keysDown[Enum.KeyCode.W] then
						move += Vector3.new(0, 0, -1)
					end

					if keysDown[Enum.KeyCode.S] then
						move += Vector3.new(0, 0, 1)
					end

					if keysDown[Enum.KeyCode.A] then
						move += Vector3.new(-1, 0, 0)
					end

					if keysDown[Enum.KeyCode.D] then
						move += Vector3.new(1, 0, 0)
					end

					if move.Magnitude > 0 then
						cameraPart.CFrame = cameraPart.CFrame * CFrame.new(move.Unit * speed * dt)
					end

					cameraPart.CFrame = CFrame.new(cameraPart.Position) * rotation
					camera.CFrame = cameraPart.CFrame
				end)

			else
				freecamActive = false
				game.Workspace:FindFirstChild("cameraPart"):Destroy()
				camera.CFrame = players.LocalPlayer.Character.Head.CFrame
				cameraLoop:Disconnect()
				cameraLoop = nil
				camera.CameraType = Enum.CameraType.Custom
				uis.MouseBehavior = Enum.MouseBehavior.Default
				uis.MouseIconEnabled = true
				playerControls:Enable()
				print("Griddle Menu (Freecam): Freecam deactivated")
			end
		end
	end
end)

uis.InputEnded:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.Keyboard then
		return
	end

	keysDown[input.KeyCode] = nil
end)

