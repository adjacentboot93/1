local function updateNameState(player)
	local count = tableCount(selectedPlayers)

	if count >= 2 and lastEspCount < 2 then
		for p in pairs(selectedPlayers) do
			createHighLightNamePart(p)
		end

	elseif count < 2 and lastEspCount >= 2 then
		for p in pairs(targetedParts) do
			removeHighlightNamePart(p)
		end

	else
		if selectedPlayers[player] then
			if count >= 2 then
				createHighLightNamePart(player)
			end
		else
			removeHighlightNamePart(player)
		end
	end

	lastEspCount = count
end

local function syncESP(player)
	local character = player.Character
	
	if not character or not character.Parent then
		return
	end
	
	local data = getPlayerData(player)

	local shouldHaveESP = selectedPlayers[player]
	
	if not shouldHaveESP then
		removeHighlightNamePart(player)
	end
	
	local character = player.Character

	if not character then return end

	if shouldHaveESP then
		if not data.highlight or not data.highlight.Parent or data.highlight.Parent ~= character then
			data.highlight = createHighlight(player, character)
		end
	else
		if data.highlight then
			local highlight = data.highlight
			data.highlight = nil

			if highlight then
				espHighlights[player] = nil
				
				playerEspCount = playerEspCount - 1
				
				local tween = tweenService:Create(highlight, TweenInfo.new(nameFadeTime), {FillTransparency = 1, OutlineTransparency = 1})

				tween:Play()

				tween.Completed:Once(function()
					if highlight and highlight.Parent then
						highlight:Destroy()
					end
				end)
			end
		end
	end

	updateNameState(player)

	if data.button then
		buttonStates[data.button] = shouldHaveESP or false
		setButtonState(data.button)
	end
end

function setButtonState(button)
	local buttonBg = button:FindFirstChild("playerNameFrame")
	if not buttonBg then
		return
	end

	local enabled = buttonStates[button] == true or hoverStates[button] == true

	local goal = enabled and targetTransparency or baseTransparency

	tweenService:Create(buttonBg, tweenInfo, goal):Play()
end

function connectButton(button)
	if connectedButtons[button] then
		return
	end

	connectedButtons[button] = true
	
	local player = players:FindFirstChild(button.Name)
	
	if not player then
		return
	end
	
	buttonStates[button] = false
	hoverStates[button] = false
	
	espRegistry[player] = espRegistry[player] or {}
	espRegistry[player].button = button

	button.Activated:Connect(function()
		local newState = not buttonStates[button]
		
		buttonStates[button] = newState
		
		setButtonState(button, newState)
		
		local player = game.Players:FindFirstChild(button.Name)
		
		if player then
			espHandler(player)
		end
	end)

	button.MouseEnter:Connect(function()
		hoverStates[button] = true
		setButtonState(button)
	end)

	button.MouseLeave:Connect(function()
		hoverStates[button] = false
		setButtonState(button)
	end)
	
	if pendingAllESP[player] then
		pendingAllESP[player] = nil
		task.defer(function()
			espHandler(player)
		end)
	end
end

function getPlayerData(player)
	if not espRegistry[player] then
		espRegistry[player] = {
			highlight = nil,
			button = nil
		}
	end

	return espRegistry[player]
end

function espHandler(player)
	local wasSelected = selectedPlayers[player] == true

	if selectedPlayers[player] then
		selectedPlayers[player] = nil
	else
		selectedPlayers[player] = true
	end

	local nowSelected = selectedPlayers[player] == true

	if allSelected and wasSelected and not nowSelected then
		allSelected = false
	end

	syncESP(player)
end

