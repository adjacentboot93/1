local function createHighlight(player, character)
	if not character then return end

	local existing = character:FindFirstChild("espHighlight")
	if existing then
		return existing
	end
	
	local espHighlight = Instance.new("Highlight")
	espHighlight.Name = "espHighlight"
	espHighlight.Parent = character
	espHighlight.FillTransparency = 0.7
	espHighlight.FillColor = Color3.fromRGB(redColorValue, greenColorValue, blueColorValue)
	espHighlight.OutlineColor = Color3.fromRGB(redColorValue, greenColorValue, blueColorValue)
	espHighlight:SetAttribute("ESPPlayer", player.UserId)
	
	return espHighlight
end

local function removeHighlightNamePart(player)
	local data = targetedParts[player]

	if data and data.part then
		data.part:Destroy()
	end

	targetedParts[player] = nil
	
	local folder = workspace:FindFirstChild("highlightNameParts")
	if folder then
		local stray = folder:FindFirstChild(player.Name)
		if stray then
			stray:Destroy()
		end
	end
end

local function createHighLightNamePart(targetedPlayer)
	local folder = workspace:FindFirstChild("highlightNameParts")
	
	if not folder then
		return
	end
	
	local existing = folder:FindFirstChild(targetedPlayer.Name)
	
	if existing then
		targetedParts[targetedPlayer] = {
			part = existing,
			character = targetedPlayer.Character
		}
		return
	end
	
	local existing = targetedParts[targetedPlayer]

	if existing
		and existing.part
		and existing.part.Parent then
		return
	end
	
	local data = targetedParts[targetedPlayer]

	if data and data.part and data.part.Parent then
		return
	end
	
	local character = targetedPlayer.Character or targetedPlayer.CharacterAdded:Wait()

	local head = character:WaitForChild("Head", 3)

	if not head then
		return
	end

	local part = Instance.new("Part")
	part.Size = Vector3.new(1, 1, 1)
	part.Anchored = true
	part.CanCollide = false
	part.Parent = game.Workspace:FindFirstChild("highlightNameParts")
	part.Name = targetedPlayer.Name
	part.Transparency = 1
	
	local espName = Instance.new("BillboardGui")
	espName.Name = "espName"
	espName.Parent = part
	espName.ExtentsOffset = Vector3.new(0, 2.5, 0)
	espName.AlwaysOnTop = true
	espName.Size = UDim2.new(0, 100 + espNameSizeValue, 0 , 25 + (espNameSizeValue / 4))
	espName.ClipsDescendants = false

	local espNameText = Instance.new("TextLabel")
	espNameText.Name = "espNameText"
	espNameText.Parent = espName
	espNameText.BackgroundTransparency = 1
	espNameText.Size = UDim2.new(0, 100 + espNameSizeValue, 0 , 25 + (espNameSizeValue / 4))
	espNameText.ClipsDescendants = false
	espNameText.FontFace = Font.fromName("RobotoMono")
	espNameText.Text = targetedPlayer.Name
	espNameText.TextColor3 = Color3.fromRGB(redColorValue, greenColorValue, blueColorValue)
	espNameText.TextScaled = true

	targetedParts[targetedPlayer] = {
		part = part,
		character = character
	}
	
	character.AncestryChanged:Connect(function(_, parent)
		if not parent then
			removeHighlightNamePart(targetedPlayer)
		end
	end)
end

