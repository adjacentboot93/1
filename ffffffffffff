local function waitForCharacterReady(character)
	if not character then
		return false
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	
	if not humanoid then
		humanoid = character:WaitForChild("Humanoid", 3)
	end

	local head = character:FindFirstChild("Head")
	
	if not head then
		head = character:WaitForChild("Head", 3)
	end

	return humanoid and head
end

local function onPlayerRespawn(player, character)
	task.spawn(function()
		if not waitForCharacterReady(character) then
			return
		end

		local data = getPlayerData(player)

		if data.highlight then
			data.highlight:Destroy()
			data.highlight = nil
		end

		removeHighlightNamePart(player)

		if selectedPlayers[player] then
			syncESP(player)
		end
	end)
end

local function setupPlayer(player)
	if respawnConnections[player] then
		return
	end
	
	respawnConnections[player] = player.CharacterAdded:Connect(function(character)
		local data = espRegistry[player]
		
		if data then
			data.highlight = nil
		end

		onPlayerRespawn(player, character)
	end)
	
	player.CharacterAdded:Connect(function(character)
		onPlayerRespawn(player, character)
