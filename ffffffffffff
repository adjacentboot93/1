local function updateEspParts(deltaTime)
	for player, data in pairs(targetedParts) do
		if not selectedPlayers[player] then
			removeHighlightNamePart(player)
			
			continue
		end
		
		local character = player.Character
		local head = character and character:FindFirstChild("Head")
		
		if not character or not head or not data.part or not data.part.Parent then
			removeHighlightNamePart(player)
			
			continue
		end
		
		local targetCF = head.CFrame * CFrame.new(0, espNamePartHeightVal, 0)
		local currentCF = data.part.CFrame
		local alpha = math.clamp(deltaTime * followSpeed, 0, 1)
		
		data.part.CFrame = currentCF:Lerp(targetCF, alpha)
	end
end

local function startESPUpdater()
	if renderConnection then
		return
	end

	renderConnection = runService.RenderStepped:Connect(function(dt)
			updateEspParts(dt)
		end)
end

local function stopESPUpdater()
	if renderConnection then
		renderConnection:Disconnect()
		renderConnection = nil
	end
end

local function updateESPUpdaterState()
	if next(targetedParts) then
		startESPUpdater()
	else
		stopESPUpdater()
	end
end

function removeHighlightNamePart(player)
	local data = targetedParts[player]
	
	if not data or not data.part then
		return
	end

	local part = data.part
	part:SetAttribute("Removing", true)
	
	targetedParts[player] = nil
	data.part = nil

	local espGui = part:FindFirstChild("espName")
	local text = espGui and espGui:FindFirstChild("espNameText")

	if text then
		local tween = tweenService:Create(text, TweenInfo.new(nameFadeTime), {TextTransparency = 1})

		tween:Play()

		tween.Completed:Once(function()
			if part and part.Parent then
				part:Destroy()
			end
		end)
	else
		part:Destroy()
	end
	
	espHighlightNames[player] = nil

	updateESPUpdaterState()
end

