local function createObjHighlight(obj)
	if itemEspHighlights[obj] then
		return
	end
	
	local espHighlight = Instance.new("Highlight")
	espHighlight.Name = "espHighlight"
	espHighlight.Parent = obj
	espHighlight.FillTransparency = 1
	espHighlight.OutlineTransparency = 1
	espHighlight.FillColor = Color3.fromRGB(redColorValue, greenColorValue, blueColorValue)
	espHighlight.OutlineColor = Color3.fromRGB(redColorValue, greenColorValue, blueColorValue)
	
	itemEspHighlights[obj] = espHighlight
	
	tweenService:Create(espHighlight, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {FillTransparency = 0.7, OutlineTransparency = 0}):Play()
end

local function removeObjHighlightFromTable(obj)
	if itemEspHighlights[obj] then
		itemEspHighlights[obj]:Destroy()
		itemEspHighlights[obj] = nil
	end
end

local function removeObjHighlight(obj)
	local highlight = itemEspHighlights[obj]

	if not highlight then
		return
	end

	local tween = tweenService:Create(highlight, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {FillTransparency = 1, OutlineTransparency = 1})

	tween:Play()

	tween.Completed:Connect(function()
		if itemEspHighlights[obj] then
			removeObjHighlightFromTable(obj)
		end
	end)
end

