targetBox.FocusLost:Connect(function(enterPressed)
	if enterPressed then
		local target = targetBox.Text
		
		local name = target
		
		local targetPlayer = players:FindFirstChild(target)
		
		playergui:FindFirstChild("griddleMenu"):FindFirstChild("espMain"):FindFirstChild("espBg"):FindFirstChild("targetBoxBg"):FindFirstChild("targetBox").Text = "Type player to target with ESP..."
		
		if targetPlayer ~= nil then
			espHandler(targetPlayer)
			allSelected = false
		else
			local findMayorValue = game.ReplicatedStorage:FindFirstChild("CurrentMayor")
			
			local function mayorFindFunc()
				local mayorValue = replicatedStorage:FindFirstChild("CurrentMayor")

				if not mayorValue then
					warn("Griddle Menu (ESP): CurrentMayor missing")
					return
				end

				local mayorName = mayorValue.Value

				if typeof(mayorName) ~= "string" or mayorName == "" then
					warn("Griddle Menu (ESP): No mayor elected")
					return
				end

				local mayorPlayer = players:FindFirstChild(mayorName)

				if not mayorPlayer then
					warn("Griddle Menu (ESP): Mayor not found in Players")
					return
				end

				espHandler(mayorPlayer)
			end
			
			local function selectAllFunc()
				allSelected = true
				
				for _, player in ipairs(players:GetPlayers()) do
					if player ~= playerLocal then
						selectedPlayers[player] = true
						syncESP(player)
					end
				end
			end
			
			local function resetAllButtons()
				for player, data in pairs(espRegistry) do
					if data.button then
						buttonStates[data.button] = false
						setButtonState(data.button)
					end
				end
			end
			
			local function deSelectAllFunc()
				allSelected = false

				local playersToUpdate = {}

				for player in pairs(selectedPlayers) do
					table.insert(playersToUpdate, player)
				end

				table.clear(selectedPlayers)

				for _, player in ipairs(playersToUpdate) do
					syncESP(player)
				end

				purgeAllNameParts()
				
				resetAllButtons()
			end
			
			if target == "#mayor" then
				mayorFindFunc()
			elseif target == "#Mayor" then	
				mayorFindFunc()
			elseif target == "#all" then
				selectAllFunc()
			elseif target == "#All" then
				selectAllFunc()
			elseif target == "#deall" then
				deSelectAllFunc()
			elseif target == "#Deall" then
				deSelectAllFunc()
			else
				print("Griddle Menu (ESP): No player with name " .. "'" .. name .. "'" .. " in server")
			end
		end
	end
	playergui:FindFirstChild("griddleMenu"):FindFirstChild("espMain"):FindFirstChild("espBg"):FindFirstChild("targetBoxBg"):FindFirstChild("targetBox").Text = "Type player to target with ESP..."
end)

