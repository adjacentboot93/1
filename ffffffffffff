		uiStroke.Transparency = 0.25
	end

	function commonGradient(parent)
		local newGradient = Instance.new("UIGradient")
		newGradient.Parent = parent
		newGradient.Rotation = 90
		newGradient.Color = ColorSequence.new{
			ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(125, 125, 125))
		}
		newGradient.Transparency = NumberSequence.new{
			NumberSequenceKeypoint.new(0, 0, 0),
			NumberSequenceKeypoint.new(1, 0.2, 0)
		}
	end

	function commonUiStrokeGradient(parent)
		local newGradient = Instance.new("UIGradient")
		newGradient.Parent = parent
		newGradient.Rotation = 45
		newGradient.Color = ColorSequence.new{
			ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
			ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 0, 0)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
		}
		newGradient.Transparency = NumberSequence.new{
			NumberSequenceKeypoint.new(0, 0, 0),
			NumberSequenceKeypoint.new(0.5, 1, 0),
			NumberSequenceKeypoint.new(1, 0, 0)
		}
	end
	
	function createGradient(parent, rotation, color1, color2, time1, time2)
		local newGradient = Instance.new("UIGradient")
		newGradient.Parent = parent
		newGradient.Rotation = rotation
		newGradient.Color = ColorSequence.new{
			ColorSequenceKeypoint.new(0, color1),
			ColorSequenceKeypoint.new(1, color2)
		}
		newGradient.Transparency = NumberSequence.new{
			NumberSequenceKeypoint.new(0, time1, 0),
			NumberSequenceKeypoint.new(1, time2, 0)
		}
	end

