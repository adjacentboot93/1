local function animateGridShift(container)
	for _, holder in ipairs(container:GetChildren()) do
		if holder:IsA("Frame") then
			local newPos = holder.AbsolutePosition
			local oldPos = lastPosition[holder]

			if oldPos then
				local delta = oldPos - newPos

				if delta.Magnitude > 0 then
					local button = holder:FindFirstChildWhichIsA("GuiObject")

					if button then
						button.Position = UDim2.new(0, delta.X, 0, delta.Y)

						tweenService:Create(button, TweenInfo.new(0.35, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Position = UDim2.new(0,0,0,0)}):Play()
					end
				end
			end
			lastPosition[holder] = newPos
		end
	end
end

