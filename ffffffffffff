--//Remove Vehicle windows button
removeVWindowsButton.Activated:Connect(function()
	if removeVWindows == false then
		removeVWindows = true
		
		for _, obj in pairs(playerVehiclesFolder:GetChildren()) do
			if obj.Name == "Humvee" then
				for _, part in ipairs(obj:GetDescendants()) do
					if part:IsA("BasePart") and part.Color == Color3.fromRGB(99,95,98) and math.abs(part.Transparency - 0.4) < 0.01 then
						part:Destroy()
					end
				end
			else
				for _, part in ipairs(obj:GetDescendants()) do
					if part.Name == "Window" then
						part:Destroy()
					end
				end
			end
		end
	else
		removeVWindows = false
	end
end)

playerVehiclesFolder.ChildAdded:Connect(function(child)
	task.delay(0.1, function()
		if not child or not child.Parent then
			return
		end
		
		if not removeVWindows then
			return
		end

		local function checkPart(part)
			if child.Name == "Humvee" then
				if part:IsA("BasePart") and part.Color == Color3.fromRGB(99,95,98) and math.abs(part.Transparency - 0.4) < 0.01 then
					part:Destroy()
				end
			else
				if part.Name == "Window" then
					part:Destroy()
				end
			end
		end

		for _, part in ipairs(child:GetDescendants()) do
			checkPart(part)
		end

		child.DescendantAdded:Connect(function(part)
			if removeVWindows then
				checkPart(part)
			end
		end)
	end)
end)

