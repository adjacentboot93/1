	espHighlight.OutlineTransparency = 1
	espHighlight.FillColor = Color3.fromRGB(redColorValue, greenColorValue, blueColorValue)
	espHighlight.OutlineColor = Color3.fromRGB(redColorValue, greenColorValue, blueColorValue)
