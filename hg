	local minX = buttonWidth / 2
	local maxX = trackWidth - buttonWidth / 2
	localX = math.clamp(localX, minX, maxX)

	local alpha = (localX - minX) / (maxX - minX)
	local value = minValueEspNameHeight + (maxValueEspNameHeight - minValueEspNameHeight) * alpha

	return value
