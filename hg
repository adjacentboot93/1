			pnigFrameUiStroke.Parent = pnigFrame
			pnigFrameUiStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
			pnigFrameUiStroke.Color = Color3.fromRGB(255, 255, 255)
			pnigFrameUiStroke.Thickness = 2.5
			pnigFrameUiStroke.Transparency = 0.25
		end
		
		playergui:FindFirstChild("griddleMenu"):FindFirstChild("espMain"):FindFirstChild("espBg"):FindFirstChild("targetBoxBg"):FindFirstChild("targetBox").Text = "Type player to target with ESP..."
		
		if targetPlayer ~= nil then
			local highlightCheck = targetPlayer.Character:FindFirstChild("espHighlight")
			local highlightNameCheck = targetPlayer.Character:FindFirstChild("espNameText", true)
			local highlightNamePartCheck = game.Workspace:FindFirstChild("highlightNameParts"):FindFirstChild(targetPlayer.Name)
			
			local noPlrsText = playergui:FindFirstChild("griddleMenu"):FindFirstChild("espMain"):FindFirstChild("espBgPlayerList"):FindFirstChild("noPlrsText")
			
			if highlightCheck then
				local tPlayerInTable = table.find(targetedPlayers, targetPlayer.Name)
				
				highlightCheck:Destroy()
				espBgPlayerList:FindFirstChild(targetPlayer.Name):Destroy()
				
				if highlightNamePartCheck then
					highlightNamePartCheck:Destroy()
				end
				
				table.remove(targetedPlayers, tPlayerInTable)
				
				if #targetedPlayers < 1 then
					noPlrsText.Visible = true
				end
				
				espNamePartsManager()
				
				print("Griddle Menu (ESP): ESP on " .. targetPlayer.Name .. " disabled")
			else
				createHighlight(targetPlayer.Character)
				createNameInGui()
				
				noPlrsText.Visible = false
				table.insert(targetedPlayers, targetPlayer.Name)
				
				espNamePartsManager()
				
				print("Griddle Menu (ESP): ESP on " .. targetPlayer.Name .. " enabled")
			end
		else
			print("Griddle Menu (ESP): No player with name " .. "'" .. name .. "'" .. " in server")
		end
	end
	playergui:FindFirstChild("griddleMenu"):FindFirstChild("espMain"):FindFirstChild("espBg"):FindFirstChild("targetBoxBg"):FindFirstChild("targetBox").Text = "Type player to target with ESP..."
end)

runService.RenderStepped:Connect(function()
	local toRemove = {}
	
	for player, data in pairs(targetedParts) do
		if not player.Parent then
			table.insert(toRemove, player)
			continue
		end
		
		local character = player.Character
		local head = character and character:FindFirstChild("Head")

		if head then
			data.part.CFrame = head.CFrame * CFrame.new(0, espNamePartHeightVal, 0)
		else
			table.insert(toRemove, player)
		end
	end
	
	for _, player in ipairs(toRemove) do
		removeHighlightNamePart(player)
	end
end)

--//Remove the esp name part and re-add it back after the player dies
local function onPlayerRespawn(player, character)
	removeHighlightNamePart(player)
	
	if table.find(targetedPlayers, player.Name) and #targetedPlayers >= 2 then
		task.wait(0.01)
		createHighLightNamePart(player)
		createHighlight(player.Character)
	end
end

for _, player in ipairs(players:GetPlayers()) do
	player.CharacterAdded:Connect(function(character)
		onPlayerRespawn(player, character)
	end)
end

players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(character)
		onPlayerRespawn(player, character)
	end)
end)

--//Remove player from list, remove player name from ESP gui, and remove the esp name part when the player leaves
players.PlayerRemoving:Connect(function(player)
	removeHighlightNamePart(player)
	
	local character = player.Character
	
	if character then
		local highlight = character:FindFirstChild("espHighlight")
		
		if highlight then
			highlight:Destroy()
		end
	end
	
	local index = table.find(targetedPlayers, player.Name)
	
	if index then
		table.remove(targetedPlayers, index)
		playergui:FindFirstChild("griddleMenu"):FindFirstChild("espMain"):FindFirstChild("espBgPlayerList"):FindFirstChild("playerNames"):FindFirstChild(player.Name):Destroy()
	end
	
	espNamePartsManager()
end)

