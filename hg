			pnigFrame.Name = "playerNameFrame"
			pnigFrame.Parent = plrNameInGui
			pnigFrame.BackgroundTransparency = 1
			pnigFrame.Size = UDim2.new(0,108,0,28)
			pnigFrame.Position = UDim2.new(0.026, 0, 0.086, 0)
			
